# Copy this file to ".env" and fill in the key for whichever provider you use.
# The provider is chosen by LLM_PROVIDER at the top of core.py (default: "openai").

# --- OpenAI (default) ---
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-openai-key-here

# --- TAMU AI (set LLM_PROVIDER = "tamu" in core.py to use this) ---
# Get the key from chat.tamu.ai -> Settings -> API Key.
TAMU_AI_API_KEY=sk-paste-your-tamu-key-here
